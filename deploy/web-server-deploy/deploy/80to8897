server {
  listen 443 ssl;
  server_name 79.174.95.69 sm-karaoke.ru www.sm-karaoke.ru;
  ssl_certificate /etc/keys/www.sm-karaoke.ru.crt;
  ssl_certificate_key /etc/keys/www.sm-karaoke.ru.key;
  location /minio/ {
    proxy_pass http://89.125.103.63:9000/;
    proxy_set_header Host 89.125.103.63;
    proxy_buffering off;
    proxy_read_timeout 60;
    proxy_send_timeout 60;
  }
  location /api/ {
    proxy_pass http://127.0.0.1:8897/api/;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_set_header Host $host;
    proxy_set_header X-Nginx-Proxy true;
    client_max_body_size 200m;
    proxy_read_timeout 300;
    proxy_send_timeout 300;
  }
  location /changerecords {
    proxy_pass http://127.0.0.1:8897/changerecords;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_set_header Host $host;
    proxy_set_header X-Nginx-Proxy true;
  }
  location /song {
    set $song_backend "http://127.0.0.1:7907";
    if ($http_user_agent ~* "vkShare") {
      set $song_backend "http://127.0.0.1:8897";
    }
    proxy_pass $song_backend;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_set_header Host $host;
    proxy_set_header X-Nginx-Proxy true;
  }
  location / {
    proxy_pass http://127.0.0.1:7907/;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_set_header Host $host;
    proxy_set_header X-Nginx-Proxy true;
  }
}

server {
  listen 80;
  server_name 79.174.95.69 sm-karaoke.ru www.sm-karaoke.ru minio-proxy;
  location /minio/ {
    proxy_pass http://89.125.103.63:9000/;
    proxy_set_header Host 89.125.103.63;
    proxy_buffering off;
    proxy_read_timeout 60;
  }
  # Обход той же MTU-проблемы (docker bridge=1500 vs физический ens3=1450), что и у /minio/ выше,
  # но для внешнего HTTPS API (Yandex SmartCaptcha /validate) — TLS handshake из контейнера напрямую
  # виснет (SslHandshakeTimeoutException), а хостовый nginx использует ens3 напрямую и не подвержен багу.
  location /smartcaptcha/ {
    proxy_ssl_server_name on;
    proxy_pass https://smartcaptcha.yandexcloud.net/;
    proxy_set_header Host smartcaptcha.yandexcloud.net;
    proxy_read_timeout 15;
    proxy_send_timeout 15;
  }
  # Тот же обход MTU black-hole, что и /smartcaptcha/ выше, но для ЮKassa API (создание платежа,
  # проверка статуса на вебхуке — PaymentService в karaoke-web). YOOKASSA_API_URL=http://minio-proxy/yookassa.
  location /yookassa/ {
    proxy_ssl_server_name on;
    proxy_pass https://api.yookassa.ru/;
    proxy_set_header Host api.yookassa.ru;
    proxy_read_timeout 15;
    proxy_send_timeout 15;
  }
  location / {
    return 301 https://sm-karaoke.ru$request_uri;
  }
}