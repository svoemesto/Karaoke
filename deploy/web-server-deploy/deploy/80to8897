server {
  listen 443 ssl;
  server_name 79.174.95.69 sm-karaoke.ru www.sm-karaoke.ru;
  ssl_certificate /etc/keys/www.sm-karaoke.ru.crt;
  ssl_certificate_key /etc/keys/www.sm-karaoke.ru.key;
  location / {
    proxy_pass http://127.0.0.1:8897/;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_set_header Host $host;
    proxy_set_header X-Nginx-Proxy true;
  }
}

server {
  listen 80;
  server_name 79.174.95.69 sm-karaoke.ru www.sm-karaoke.ru;
  return 301 https://sm-karaoke.ru$request_uri;
}